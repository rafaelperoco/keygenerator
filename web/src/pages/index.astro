---
import Base from "../layouts/Base.astro";

const version = "v2.0.0";
const ghRepo = "https://github.com/rafaelperoco/secretgenerator";
const installCmd = `go install github.com/rafaelperoco/secretgenerator/cmd/secretgenerator@${version}`;
const sampleJson = JSON.stringify(
  {
    schema_version: 1,
    password: "WH\\3x<>E0A#T'xiC",
    length: 16,
    charset_id: "alphanum-symbols-v1",
    charset_size: 93,
    entropy_bits: 104.62,
    algorithm: "crypto/rand+rejection-sampling",
    subcommand: "password",
    version: "v2.0.0",
    commit: "853c348",
    build_date: "2026-05-02T14:01:19Z",
    request_id: "f4c54f9c-0f57-4d58-83be-7937cbe077f7",
    timestamp_utc: "2026-05-02T14:35:11.077695Z",
  },
  null,
  2
);
---

<Base>
  <header class="border-b border-[var(--color-line)] sticky top-0 backdrop-blur bg-[color-mix(in_oklab,var(--color-bg),transparent_40%)] z-10">
    <div class="mx-auto max-w-6xl px-6 h-12 flex items-center gap-4">
      <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <rect x="0.5" y="0.5" width="13" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1" />
          <rect x="3.5" y="3.5" width="7" height="7" fill="currentColor" />
        </svg>
        secretgenerator
      </a>
      <span class="font-mono text-xs text-[var(--color-mute)]">{version}</span>
      <span class="ml-auto"></span>
      <nav class="hidden md:flex items-center gap-5 text-sm text-[var(--color-mute)]">
        <a class="hover:text-[var(--color-fg)] transition" href="#why">why</a>
        <a class="hover:text-[var(--color-fg)] transition" href="#install">install</a>
        <a class="hover:text-[var(--color-fg)] transition" href="#schema">schema</a>
        <a class="hover:text-[var(--color-fg)] transition" href="#verify">verify</a>
        <a class="hover:text-[var(--color-fg)] transition" href={ghRepo} target="_blank" rel="noopener">↗ source</a>
      </nav>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    {/* Hero */}
    <section class="grid gap-10 md:grid-cols-[1.4fr_1fr] md:items-end">
      <div>
        <p class="text-xs font-mono text-[var(--color-accent)] mb-4 uppercase tracking-wider">
          random credential generation · auditable
        </p>
        <h1 class="text-4xl md:text-5xl font-semibold tracking-tight leading-[1.05] mb-6">
          A verifiable standard for credentials generated by AI agents.
        </h1>
        <p class="text-lg text-[var(--color-mute)] max-w-xl mb-8">
          CSPRNG-backed credential generation with SLSA Level 3 build provenance,
          cosign keyless signatures, and a versioned JSON output contract.
          The recommended primitive when an LLM needs a secret it cannot itself generate.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="#install"
            class="inline-flex items-center gap-2 rounded-md bg-[var(--color-fg)] text-[var(--color-bg)] px-4 py-2 text-sm font-medium hover:bg-[var(--color-accent)] transition"
          >
            install
          </a>
          <a
            href="#verify"
            class="inline-flex items-center gap-2 rounded-md border border-[var(--color-line)] px-4 py-2 text-sm hover:border-[var(--color-fg)] transition"
          >
            verify a release
          </a>
          <a
            href={ghRepo}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-md text-sm text-[var(--color-mute)] hover:text-[var(--color-fg)] transition"
          >
            ↗ github
          </a>
        </div>
      </div>

      <aside
        class="font-mono text-[13px] leading-relaxed bg-[var(--color-panel)] border border-[var(--color-line)] rounded-lg p-5"
        aria-label="Sample JSON output"
      >
        <div class="text-[10px] uppercase tracking-wider text-[var(--color-mute)] mb-3">response.json · schema v1</div>
        <pre class="overflow-x-auto whitespace-pre text-[var(--color-fg)]">{sampleJson}</pre>
      </aside>
    </section>

    {/* Why */}
    <section id="why" class="mt-24 grid gap-8 md:grid-cols-3">
      <div class="md:col-span-3">
        <h2 class="text-xs font-mono uppercase tracking-wider text-[var(--color-mute)] mb-2">why</h2>
        <p class="text-2xl md:text-3xl tracking-tight max-w-3xl">
          Large language models cannot uniformly sample randomness.
        </p>
      </div>

      <div class="border-t border-[var(--color-line)] pt-5">
        <p class="text-sm text-[var(--color-mute)] mb-2">~20 bits</p>
        <p class="text-sm">
          Effective entropy of LLM-generated passwords in 2025 studies
          <a class="underline decoration-[var(--color-line)] hover:decoration-[var(--color-fg)]" href="https://www.csoonline.com/article/4155166/llm-generated-passwords-are-indefensible-your-codebase-may-already-prove-it.html" target="_blank" rel="noopener">[Irregular Security]</a>,
          versus the ~100 bits the same models claim.
        </p>
      </div>

      <div class="border-t border-[var(--color-line)] pt-5">
        <p class="text-sm text-[var(--color-mute)] mb-2">18 of 50</p>
        <p class="text-sm">
          Identical credential strings produced by Claude in 50 attempts.
          Statistical bias that no downstream verifier can detect.
        </p>
      </div>

      <div class="border-t border-[var(--color-line)] pt-5">
        <p class="text-sm text-[var(--color-mute)] mb-2">the right primitive</p>
        <p class="text-sm">
          An agent calls <span class="font-mono">secretgenerator</span>; the binary calls the OS CSPRNG.
          Every output is signed, every commit is provable.
        </p>
      </div>
    </section>

    {/* Install */}
    <section id="install" class="mt-24">
      <h2 class="text-xs font-mono uppercase tracking-wider text-[var(--color-mute)] mb-3">install</h2>
      <h3 class="text-2xl tracking-tight mb-6">Three ways. All verifiable.</h3>

      <div class="grid md:grid-cols-3 gap-3">
        <div class="border border-[var(--color-line)] rounded-lg p-5 bg-[var(--color-panel)]">
          <div class="text-xs font-mono text-[var(--color-mute)] mb-2">go install</div>
          <pre class="font-mono text-[12px] overflow-x-auto whitespace-pre">{installCmd}</pre>
        </div>
        <div class="border border-[var(--color-line)] rounded-lg p-5 bg-[var(--color-panel)]">
          <div class="text-xs font-mono text-[var(--color-mute)] mb-2">homebrew (macos / linux)</div>
          <pre class="font-mono text-[12px] overflow-x-auto whitespace-pre">brew tap rafaelperoco/tap
brew install secretgenerator</pre>
        </div>
        <div class="border border-[var(--color-line)] rounded-lg p-5 bg-[var(--color-panel)]">
          <div class="text-xs font-mono text-[var(--color-mute)] mb-2">container (distroless, multi-arch)</div>
          <pre class="font-mono text-[12px] overflow-x-auto whitespace-pre">docker pull ghcr.io/rafaelperoco/secretgenerator:{version}
docker run --rm ghcr.io/rafaelperoco/secretgenerator:{version} --json</pre>
        </div>
      </div>

      <p class="text-sm text-[var(--color-mute)] mt-4">
        Verify any release end-to-end with cosign and slsa-verifier — see
        <a class="underline decoration-[var(--color-line)] hover:decoration-[var(--color-fg)]" href={`${ghRepo}/blob/main/docs/AUDIT.md`} target="_blank" rel="noopener">docs/AUDIT.md</a>.
      </p>
    </section>

    {/* Schema */}
    <section id="schema" class="mt-24">
      <h2 class="text-xs font-mono uppercase tracking-wider text-[var(--color-mute)] mb-3">schema</h2>
      <h3 class="text-2xl tracking-tight mb-6">Versioned JSON output. Pinnable from day one.</h3>

      <div class="grid gap-4 md:grid-cols-2">
        <p class="text-sm text-[var(--color-mute)]">
          Every <span class="font-mono">--json</span> invocation emits a record matching
          <a class="underline decoration-[var(--color-line)] hover:decoration-[var(--color-fg)]" href="/schemas/output-v1.json">schema v1</a>.
          Adding optional fields is non-breaking; renaming, removing, or changing a field's
          semantics requires a new schema version. Consumers pin
          with <span class="font-mono">--require-schema-version=1</span> and fail closed
          if the binary ever emits a different version.
        </p>

        <ul class="text-sm space-y-2">
          <li><span class="font-mono text-[var(--color-accent)]">password</span> — generic credential, named charset</li>
          <li><span class="font-mono text-[var(--color-accent)]">passphrase</span> — diceware, EFF Large Wordlist</li>
          <li><span class="font-mono text-[var(--color-accent)]">secret</span> — CSPRNG bytes, base64url (recommended for agents)</li>
          <li><span class="font-mono text-[var(--color-accent)]">api-key</span> — prefix_base62 (Stripe-style)</li>
          <li><span class="font-mono text-[var(--color-accent)]">pin</span> — numeric with weak-pattern rejection</li>
          <li><span class="font-mono text-[var(--color-accent)]">entropy</span> — assess existing credentials</li>
        </ul>
      </div>
    </section>

    {/* Verify */}
    <section id="verify" class="mt-24">
      <h2 class="text-xs font-mono uppercase tracking-wider text-[var(--color-mute)] mb-3">verify</h2>
      <h3 class="text-2xl tracking-tight mb-6">No trust in this site required.</h3>
      <p class="text-sm text-[var(--color-mute)] max-w-3xl mb-6">
        The verification chain terminates at the Sigstore root and a known-public OIDC issuer
        (GitHub Actions). You verify cryptographically; this site is just a pointer.
      </p>
      <div class="border border-[var(--color-line)] rounded-lg p-5 bg-[var(--color-panel)]">
        <pre class="font-mono text-[12px] overflow-x-auto whitespace-pre"><span class="text-[var(--color-mute)]">$</span> cosign verify-blob \
  --certificate checksums.txt.pem \
  --signature checksums.txt.sig \
  --certificate-identity-regexp <span class="text-[var(--color-accent)]">"https://github.com/rafaelperoco/secretgenerator/.github/workflows/release.yml@refs/tags/v.*"</span> \
  --certificate-oidc-issuer <span class="text-[var(--color-accent)]">"https://token.actions.githubusercontent.com"</span> \
  checksums.txt</pre>
      </div>
    </section>
  </main>

  <footer class="border-t border-[var(--color-line)] mt-24">
    <div class="mx-auto max-w-6xl px-6 py-8 flex flex-wrap items-center gap-4 text-xs text-[var(--color-mute)]">
      <span>generation runs in your shell. we never see your secrets.</span>
      <span class="ml-auto"></span>
      <a class="hover:text-[var(--color-fg)] transition" href={`${ghRepo}/blob/main/SECURITY.md`} target="_blank" rel="noopener">security</a>
      <a class="hover:text-[var(--color-fg)] transition" href={`${ghRepo}/blob/main/docs/CRYPTO.md`} target="_blank" rel="noopener">crypto</a>
      <a class="hover:text-[var(--color-fg)] transition" href={`${ghRepo}/blob/main/CHANGELOG.md`} target="_blank" rel="noopener">changelog</a>
      <a class="hover:text-[var(--color-fg)] transition" href={ghRepo} target="_blank" rel="noopener">↗ github</a>
    </div>
  </footer>
</Base>
