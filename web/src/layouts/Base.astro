---
import "../styles/global.css";
import JsonLd from "../components/JsonLd.astro";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  jsonLd?: boolean;
}

const {
  title = "secretgenerator — auditable credentials for AI agents",
  description = "Auditable random credential generator with SLSA Level 3 build provenance, cosign keyless signatures, and a versioned JSON output contract. CSPRNG-backed, schema-pinnable, designed for invocation by AI agents.",
  path = "/",
  jsonLd = true,
} = Astro.props;

const site = Astro.site ?? new URL("https://secretgenerator.org");
const canonical = new URL(path, site).href;
const ogImage = new URL("/og-image.png", site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="secretgenerator" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="secretgenerator — A verifiable standard for credentials generated by AI agents" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="secretgenerator — A verifiable standard for credentials generated by AI agents" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {jsonLd && <JsonLd />}
  </head>
  <body class="min-h-dvh bg-[var(--color-bg)] text-[var(--color-fg)]">
    <slot />
  </body>
</html>
